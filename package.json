{
  "name": "photography-shelf",
  "version": "1.0.3",
  "description": "Shelf — a pixel-elf-themed photo darkroom for sorting camera raws",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -n server,vite -c blue,magenta \"node server/index.js\" \"vite\"",
    "server": "node server/index.js",
    "build": "vite build",
    "electron:dev": "concurrently -n server,vite,electron -c blue,magenta,cyan \"node server/index.js\" \"vite\" \"wait-on http://localhost:5173 && electron electron/main.js\"",
    "electron:build": "npm run build && electron-builder",
    "test": "playwright test",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "cors": "^2.8.5",
    "exiftool-vendored": "^28.0.0",
    "express": "^5.1.0",
    "get-port": "^7.2.0",
    "open": "^10.1.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.4.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.elf.shelf",
    "productName": "Shelf",
    "asar": true,
    "asarUnpack": [
      "node_modules/**/*",
      "server/**/*",
      "dist/**/*",
      "package.json"
    ],
    "files": [
      "electron/**/*",
      "server/**/*",
      "!server/test/**",
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [],
    "directories": {
      "output": "dist-electron",
      "buildResources": "electron/icon"
    },
    "mac": {
      "category": "public.app-category.photography",
      "target": [
        "dmg"
      ],
      "icon": "electron/icon/source.png",
      "identity": null
    },
    "afterPack": "scripts/after-pack.mjs",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "electron/icon/source.png"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
